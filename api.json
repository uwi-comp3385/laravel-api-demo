                                        "message": {
                                            "type": "string",
                                            "const": "User created successfully"
                                        },
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        },
                                        "authorisation": {
                                            "type": "object",
                                            "properties": {
                                                "token": {
                                                    "type": "string"
                                                },
                                                "type": {
                                                    "type": "string",
                                                    "const": "bearer"
                                                }
                                            },
                                            "required": [
                                                "token",
                                                "type"
                                            ]
                                        }
