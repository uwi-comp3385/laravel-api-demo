                                        "status": {
                                            "type": "string",
                                            "const": "success"
                                        },
                                        "user": {
                                            "type": "string"
                                        },
                                        "authorisation": {
                                            "type": "object",
                                            "properties": {
                                                "token": {
                                                    "type": "string"
                                                },
                                                "type": {
                                                    "type": "string",
                                                    "const": "bearer"
                                                }
                                            },
                                            "required": [
